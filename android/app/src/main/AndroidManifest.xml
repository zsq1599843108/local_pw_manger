<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      AOAP needs no permissions: USB_ACCESSORY_ATTACHED is delivered to apps
      that match accessory_filter.xml, and the system grants per-attach access.
      BiometricPrompt also needs no manifest permission — androidx handles it
      via the framework. Internet permission stays absent — this APK is offline.
    -->

    <application
        android:label="@string/app_name"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:theme="@style/Theme.PassMan">

        <!--
          Visible launcher entry (BiometricDemo). The user opens us from the
          app drawer to validate fingerprint / debug. UsbAccessoryActivity
          stays USB-only so plugging in is the only way it shows up.
        -->
        <activity
            android:name=".BiometricDemoActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Triggered ONLY by USB plug-in. Theme.NoDisplay = no UI at all. -->
        <activity
            android:name=".UsbAccessoryActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_ACCESSORY_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_ACCESSORY_ATTACHED"
                android:resource="@xml/accessory_filter" />
        </activity>

    </application>

</manifest>
